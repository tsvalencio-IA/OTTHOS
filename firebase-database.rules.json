{
  "rules": {
    "otthosWorld": {
      "users": {
        "$uid": {
          "profile": {
            ".read": "auth != null",
            ".write": "auth != null && auth.uid === $uid"
          },
          "progress": {
            ".read": "auth != null && auth.uid === $uid",
            ".write": "auth != null && auth.uid === $uid"
          },
          "inbox": {
            "$giftId": {
              ".read": "auth != null && auth.uid === $uid",
              ".write": "auth != null && (auth.uid === $uid || (!data.exists() && newData.child('senderUid').val() === auth.uid))"
            }
          },
          "interactions": {
            "$eventId": {
              ".read": "auth != null && auth.uid === $uid",
              ".write": "auth != null && (auth.uid === $uid || (!data.exists() && newData.child('senderUid').val() === auth.uid))"
            }
          }
        }
      },
      "publicWorld": {
        "presence": {
          ".read": "auth != null",
          "$uid": {
            ".write": "auth != null && auth.uid === $uid",
            ".validate": "!newData.exists() || (newData.hasChildren(['name','x','y','z','r','updatedAt']) && newData.child('name').isString() && newData.child('name').val().length >= 3 && newData.child('name').val().length <= 24)"
          }
        },
        "chat": {
          ".read": "auth != null",
          "$messageId": {
            ".write": "auth != null && !data.exists() && newData.child('senderUid').val() === auth.uid",
            ".validate": "newData.hasChildren(['senderUid','name','text','createdAt']) && newData.child('text').isString() && newData.child('text').val().length > 0 && newData.child('text').val().length <= 180"
          }
        },
        "houses": {
          ".read": "auth != null",
          "$houseId": {
            ".write": "auth != null && ((!data.exists() && newData.child('ownerUid').val() === auth.uid) || (data.child('ownerUid').val() === auth.uid && newData.child('ownerUid').val() === auth.uid))",
            ".validate": "newData.hasChildren(['ownerUid','ownerName','name','locked','updatedAt'])"
          }
        }
      }
    }
  }
}
